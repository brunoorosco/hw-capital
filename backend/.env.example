# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hw_capital?schema=public"

# Server
PORT=3333
NODE_ENV=development
LOG_PRETTY=true
# JWT (for Google Auth and general token signing)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=hw-capital-files
CLOUDFLARE_R2_PUBLIC_URL=https://your-public-r2-url.com

# CORS
CORS_ORIGIN=http://localhost:5173

# Google OAuth (Frontend)
# Get your Client ID from: https://console.cloud.google.com/
# This is your FRONTEND Client ID (not backend secret)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
